{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "docker:enableMajor",
        ":disableRateLimiting",
        ":dependencyDashboard",
        ":semanticCommitTypeAll(chore)",
        ":label(dependencies)"
    ],
    "dependencyDashboardTitle": "Renovate Dashboard",
    "ignorePaths": [
        "**/*.secret.*",
        ".sops.yaml"
    ],
    "argocd": {
        "managerFilePatterns": [
            "/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"
        ]
    },
    "helm-values": {
        "managerFilePatterns": [
            "/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"
        ]
    },
    "helmfile": {
        "managerFilePatterns": [
            "/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"
        ]
    },
    "kubernetes": {
        "managerFilePatterns": [
            "/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"
        ]
    },
    "kustomize": {
        "managerFilePatterns": [
            "/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"
        ]
    }
}