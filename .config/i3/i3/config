# Appearance
font pango:monospace 8

gaps outer 25
gaps inner 35

default_border none

# Per-Application
for_window [class="Pavucontrol"] floating enable
for_window [class="Nm-connection-editor"] floating enable

# Keybindings
set $mod Mod4
set $alt Mod1
floating_modifier $mod

bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

bindsym XF86MonBrightnessUp exec xbacklight -inc 20
bindsym XF86MonBrightnessDown exec xbacklight -dec 20

bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioPause exec playerctl stop
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

bindsym Ctrl+$alt+Up exec playerctl play-pause
bindsym Ctrl+$alt+Down exec playerctl stop
bindsym Ctrl+$alt+Right exec playerctl next
bindsym Ctrl+$alt+Left exec playerctl previous

bindsym Print exec flameshot gui

bindsym $mod+Return exec alacritty

bindsym $mod+q kill
bindsym $alt+F4 kill

bindsym $mod+space exec --no-startup-id ~/.bin/launcher

bindsym $mod+Escape exec --no-startup-id ~/.bin/powermenu

bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+Ctrl+Left resize shrink width 10 px or 10 ppt
bindsym $mod+Ctrl+Down resize grow height 10 px or 10 ppt
bindsym $mod+Ctrl+Up resize shrink height 10 px or 10 ppt
bindsym $mod+Ctrl+Right resize grow width 10 px or 10 ppt

bindsym $mod+h split h
bindsym $mod+v split v

bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+Shift+space floating toggle

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

bindsym $mod+$alt+Left exec ~/.bin/i3moreworkspaces.sh movefocus -1
bindsym $mod+$alt+Right exec ~/.bin/i3moreworkspaces.sh movefocus 1

bindsym $mod+$alt+Shift+Left exec ~/.bin/i3moreworkspaces.sh movecontainer -1 
bindsym $mod+$alt+Shift+Right exec ~/.bin/i3moreworkspaces.sh movecontainer 1

bindsym $mod+o move workspace to output left
bindsym $mod+p move workspace to output right

bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

bindsym $mod+l exec ~/.bin/fancylock

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"


# Start Environment
exec_always --no-startup-id dex --autostart --environment i3
exec_always --no-startup-id xss-lock --transfer-sleep-lock -- fancylock
exec_always --no-startup-id picom
exec_always --no-startup-id ~/.config/polybar/start.sh
exec_always --no-startup-id nitrogen --restore
exec_always --no-startup-id dunst --config ~/.config/dunst/dunstrc
#for some reason pulseaudio doesn't work as a service so i start it manually here, you might not need this
exec_always --no-startup-id pulseaudio -c --exit-idle-time=-1 --disallow-exit=true

# Autolaunch Programs
exec Discord
exec flatpak run org.telegram.desktop
exec flatpak run com.spotify.Client
